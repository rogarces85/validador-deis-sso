# ============================================================
# Configuracion de entorno para el backend PHP del validador.
# Copie este archivo a `.env` (NO se commitea) y complete los
# valores. Las variables aqui listadas se leen desde el entorno
# del proceso PHP (Apache o CLI) al ejecutar scripts y endpoints.
# ============================================================

# --- Base de datos ---
# Host del servidor MySQL/MariaDB del Servicio de Salud.
DB_HOST=10.8.152.199
DB_PORT=3306
DB_NAME=validador_rem
DB_USER=root
# Contrasena root de MySQL. Mantener fuera del repositorio.
# En Apache se puede definir via SetEnv en httpd.conf o .htaccess.
# En CLI:   $env:DB_PASS="..." ; php scripts/migrate.php
DB_PASS=

# --- Sesion admin ---
# Nombre de la cookie de sesion (cambiar si se despliegan varias instancias).
SESSION_NAME=deis_admin_session
# Tiempo de vida de la sesion en segundos (default 1800 = 30 min).
SESSION_LIFETIME=1800

# --- CORS ---
# Vacio = mismo origen (recomendado para produccion).
# En desarrollo con Vite dev server, usar la URL del frontend, p. ej.:
#   CORS_ORIGIN=http://localhost:3000
CORS_ORIGIN=
